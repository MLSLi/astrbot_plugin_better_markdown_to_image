{
    "chromedriver_path": {
        "description": "chromedriver地址",
        "type": "string",
        "hint": "你的chromedriver地址",
        "default": "/usr/bin/chromedriver"
    },
    "output_image_width": {
        "description": "输出图片长度",
        "type": "int",
        "hint": "",
        "default": 1200
    },
    "output_image_height": {
        "description": "输出图片高度，如果高度自适应(超出输出内容才会生效)未生效",
        "type": "int",
        "hint": "",
        "default": 800
    },
    "background_image": {
        "description": "背景图片",
        "type": "string",
        "hint": "如果需要的话，输入背景图片的路径",
        "default": ""
    },
    "is_dark_theme": {
        "description": "是否为暗色主题，默认为亮色",
        "type": "bool",
        "hint": "",
        "default": false
    },
    "output_link": {
        "description": "是否输出Markdown内的链接",
        "type": "bool",
        "hint": "",
        "default": false
    },
    "md2img_len_limit": {
        "description": "LLM输出结果超过字数超过多少后转为图片，小于等于0则禁用，注意转为图片后不会再发送文字消息",
        "type": "int",
        "hint": "",
        "default": 100
    },
    "padding_below": {
        "description": "如果高度自适应生效，对于生成的图片，向下填充多少个像素",
        "type": "int",
        "hint": "",
        "default": 50
    },
    "device_scale_factor": {
        "description": "设备缩放系数，一般为1.0",
        "type": "float",
        "hint": "",
        "default": 1.0
    }
}